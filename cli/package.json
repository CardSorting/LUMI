{
	"name": "dietcode-cli",
	"version": "4.1.0",
	"description": "Autonomous coding agent CLI - capable of creating/editing files, running commands, using the browser, and more",
	"main": "dist/lib.mjs",
	"types": "dist/lib.d.ts",
	"bin": {
		"dietcode": "./dist/cli.mjs"
	},
	"exports": {
		".": {
			"import": "./dist/lib.mjs",
			"types": "./dist/lib.d.ts"
		}
	},
	"os": [
		"darwin",
		"linux",
		"win32"
	],
	"cpu": [
		"x64",
		"arm64"
	],
	"man": "./man/dietcode.1",
	"type": "module",
	"engines": {
		"node": ">=20.0.0"
	},
	"scripts": {
		"package:brew": "npx tsx ./scripts/update-brew-formula.mts",
		"package": "npm pack --pack-destination ./dist",
		"build": "npm run typecheck && npx tsx esbuild.mts && npm run build:types",
		"build:production": "npx tsx esbuild.mts --production && npm run build:types",
		"build:types": "(npx tsc -p tsconfig.lib.json || true) && cp dist/types/cli/src/exports.d.ts dist/lib.d.ts && mkdir -p dist/agent && cp dist/types/cli/src/agent/DietCodeAgent.d.ts dist/types/cli/src/agent/DietCodeSessionEmitter.d.ts dist/types/cli/src/agent/public-types.d.ts dist/agent/ && rm -rf dist/types",
		"watch": "npx tsx esbuild.mts --watch",
		"dev": "IS_DEV=true && npm run link && npm run watch ; npm run unlink",
		"clean": "rimraf dist",
		"typecheck": "npx tsc --noEmit",
		"link": "npm run build && npm link",
		"unlink": "npm unlink -g dietcode",
		"test": "vitest",
		"test:run": "vitest run"
	},
	"keywords": [
		"dietcode",
		"claude",
		"dev",
		"mcp",
		"openrouter",
		"coding",
		"agent",
		"autonomous",
		"chatgpt",
		"sonnet",
		"ai",
		"llama",
		"cli"
	],
	"author": {
		"name": "DietCode Bot Inc."
	},
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/cardsorting/dietcode"
	},
	"homepage": "https://dietcode.io",
	"bugs": {
		"url": "https://github.com/cardsorting/dietcode/issues"
	},
	"devDependencies": {
		"@octokit/webhooks-types": "^7.6.1",
		"@types/marked": "^5.0.2",
		"@types/node": "20.x",
		"@types/prompts": "^2.4.9",
		"@types/react": "^19.2.9",
		"dotenv": "^16.4.5",
		"esbuild": "^0.25.0",
		"ink-testing-library": "^4.0.0",
		"rimraf": "^6.0.1",
		"typescript": "^5.4.5",
		"vitest": "^4.0.17"
	},
	"dependencies": {
		"@actions/core": "^3.0.0",
		"@actions/github": "^9.1.0",
		"@agentclientprotocol/sdk": "^0.13.1",
		"@clack/prompts": "^1.2.0",
		"@octokit/rest": "^22.0.1",
		"@types/yargs": "^17.0.35",
		"@vscode/ripgrep": "^1.15.9",
		"aws4fetch": "^1.0.20",
		"chalk": "^5.3.0",
		"commander": "^12.1.0",
		"ink": "npm:@jrichman/ink@6.4.7",
		"ink-picture": "^1.3.3",
		"ink-spinner": "^5.0.0",
		"jsonc-parser": "^3.3.1",
		"marked": "^17.0.3",
		"nanoid": "^5.1.6",
		"ora": "^8.0.1",
		"pino": "^10.0.0",
		"pino-roll": "^4.0.0",
		"prompts": "^2.4.2",
		"react": "^19.2.3",
		"yargs": "^18.0.0"
	}
}
