#!/usr/bin/env sh
# Conventional Commits — matches .github/workflows/pr-title.yml
commit_msg=$(cat "$1")
header=$(echo "$commit_msg" | head -n1)

if echo "$header" | grep -qE '^(Merge |Revert |fixup!|squash!)'; then
  exit 0
fi

if ! echo "$header" | grep -qE '^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?: .+'; then
  echo "commit-msg: use Conventional Commits (e.g. feat: add roadmap projection)" >&2
  echo "  got: $header" >&2
  exit 1
fi
