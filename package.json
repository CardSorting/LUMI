{
	"name": "lumi-vscode",
	"displayName": "LUMI",
	"description": "LUMI is your calm coding companion — comfort-first developer tooling for long sessions.",
	"version": "2.9.2",
	"icon": "assets/icons/icon.png",
	"workspaces": [
		".",
		"broccolidb"
	],
	"engines": {
		"vscode": "^1.84.0"
	},
	"author": {
		"name": "DietCode Inc."
	},
	"license": "Apache-2.0",
	"publisher": "CardSorting",
	"repository": {
		"type": "git",
		"url": "https://github.com/CardSorting/LUMI"
	},
	"homepage": "https://dietcode.io",
	"categories": [
		"AI",
		"Chat",
		"Programming Languages",
		"Education",
		"Snippets",
		"Testing"
	],
	"keywords": [
		"lumi",
		"dietcode",
		"claude",
		"dev",
		"mcp",
		"openrouter",
		"coding",
		"agent",
		"autonomous",
		"chatgpt",
		"sonnet",
		"ai",
		"llama"
	],
	"activationEvents": [
		"onLanguage",
		"onUri",
		"onStartupFinished",
		"workspaceContains:evals.env"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"icons": {
			"lumi-icon": {
				"description": "LUMI",
				"default": {
					"fontPath": "assets/icons/mira-bot.woff",
					"fontCharacter": "\\e900"
				}
			}
		},
		"walkthroughs": [
			{
				"id": "LUMIWalkthrough",
				"title": "Meet LUMI, your calm coding companion",
				"description": "LUMI codes like a developer because it thinks like one. Here are 5 ways to put it to work:",
				"steps": [
					{
						"id": "welcome",
						"title": "Start with a Goal, Not Just a Prompt",
						"description": "Tell LUMI what you want to achieve. It plans, asks, and then codes, like a true partner.",
						"media": {
							"markdown": "walkthrough/step1.md"
						}
					},
					{
						"id": "learn",
						"title": "Let LUMI learn your codebase",
						"description": "Point LUMI to your project. It builds understanding to make smart, context-aware changes.",
						"media": {
							"markdown": "walkthrough/step2.md"
						}
					},
					{
						"id": "advanced-features",
						"title": "Always Use the Best AI Models",
						"description": "LUMI connects you with State-of-the-Art AI, connecting to top models (Anthropic, Gemini, OpenAI & more).",
						"media": {
							"markdown": "walkthrough/step3.md"
						}
					},
					{
						"id": "mcp",
						"title": "Extend with Powerful Tools (MCP)",
						"description": "Connect to databases, APIs, or discover new capabilities in the MCP Marketplace.",
						"media": {
							"markdown": "walkthrough/step4.md"
						}
					},
					{
						"id": "getting-started",
						"title": "You're Always in Control",
						"description": "Review LUMI's plans and diffs. Approve changes before they happen. No surprises.",
						"media": {
							"markdown": "walkthrough/step5.md"
						},
						"content": {
							"path": "walkthrough/step5.md"
						}
					}
				]
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "lumi-ActivityBar",
					"title": "LUMI",
					"icon": "assets/icons/icon.svg"
				}
			]
		},
		"views": {
			"lumi-ActivityBar": [
				{
					"type": "webview",
					"id": "lumi.SidebarProvider",
					"name": "LUMI",
					"icon": "assets/icons/icon.svg"
				}
			]
		},
		"commands": [
			{
				"command": "lumi.plusButtonClicked",
				"title": "New Task",
				"icon": "$(add)"
			},
			{
				"command": "lumi.mcpButtonClicked",
				"title": "MCP Servers",
				"icon": "$(server)"
			},
			{
				"command": "lumi.historyButtonClicked",
				"title": "History",
				"icon": "$(history)"
			},
			{
				"command": "lumi.accountButtonClicked",
				"title": "Account",
				"icon": "$(account)"
			},
			{
				"command": "lumi.settingsButtonClicked",
				"title": "Settings",
				"icon": "$(settings-gear)"
			},
			{
				"command": "lumi.joyZoningButtonClicked",
				"title": "JoyZoning Audit",
				"icon": "$(shield)"
			},
			{
				"command": "lumi.joyZoningAudit",
				"title": "Run JoyZoning Audit",
				"category": "LUMI",
				"icon": "$(shield)"
			},
			{
				"command": "lumi.dev.createTestTasks",
				"title": "Create Test Tasks",
				"category": "LUMI",
				"when": "dietcode.isDevMode"
			},
			{
				"command": "lumi.dev.expireMcpOAuthTokens",
				"title": "Expire MCP OAuth Tokens (for testing)",
				"category": "LUMI",
				"when": "dietcode.isDevMode"
			},
			{
				"command": "lumi.addToChat",
				"title": "Add to LUMI",
				"category": "LUMI"
			},
			{
				"command": "lumi.addTerminalOutputToChat",
				"title": "Add to LUMI",
				"category": "LUMI"
			},
			{
				"command": "lumi.focusChatInput",
				"title": "Jump to Chat Input",
				"category": "LUMI"
			},
			{
				"command": "lumi.generateGitCommitMessage",
				"title": "Generate Commit Message with LUMI",
				"category": "LUMI",
				"icon": "$(lumi-icon)"
			},
			{
				"command": "lumi.abortGitCommitMessage",
				"title": "Generate Commit Message with LUMI - Stop",
				"category": "LUMI",
				"icon": "$(debug-stop)"
			},
			{
				"command": "lumi.explainCode",
				"title": "Explain with LUMI",
				"category": "LUMI"
			},
			{
				"command": "lumi.improveCode",
				"title": "Improve with LUMI",
				"category": "LUMI"
			},
			{
				"command": "lumi.jupyterGenerateCell",
				"title": "Generate Jupyter Cell with LUMI",
				"category": "LUMI",
				"icon": "$(sparkle)"
			},
			{
				"command": "lumi.jupyterExplainCell",
				"title": "Explain Jupyter Cell with LUMI",
				"category": "LUMI",
				"icon": "$(question)"
			},
			{
				"command": "lumi.jupyterImproveCell",
				"title": "Improve Jupyter Cell with LUMI",
				"category": "LUMI",
				"icon": "$(lightbulb)"
			},
			{
				"command": "lumi.openWalkthrough",
				"title": "Open Walkthrough",
				"category": "LUMI"
			},
			{
				"command": "lumi.runHealthCheck",
				"title": "Check LUMI Installation",
				"category": "LUMI",
				"icon": "$(heart)"
			},
			{
				"command": "lumi.reconstructTaskHistory",
				"title": "Reconstruct Task History",
				"category": "LUMI"
			},
			{
				"command": "lumi.reviewComment.reply",
				"title": "Reply",
				"category": "LUMI",
				"enablement": "!commentIsEmpty"
			},
			{
				"command": "lumi.reviewComment.addToChat",
				"title": "Add to LUMI Chat",
				"category": "LUMI",
				"icon": "$(link-external)"
			},
			{
				"command": "antigravity.importAntigravitySettings",
				"title": "Import Antigravity Settings",
				"category": "Antigravity"
			},
			{
				"command": "antigravity.importAntigravityExtensions",
				"title": "Import Antigravity Extensions",
				"category": "Antigravity"
			},
			{
				"command": "antigravity.prioritized.chat.open",
				"title": "Open Prioritized Chat",
				"category": "Antigravity"
			}
		],
		"keybindings": [
			{
				"command": "editor.action.submitComment",
				"key": "enter",
				"when": "commentEditorFocused && commentController == dietcode-review && !commentIsEmpty"
			},
			{
				"command": "lumi.addToChat",
				"key": "cmd+'",
				"mac": "cmd+'",
				"win": "ctrl+'",
				"linux": "ctrl+'",
				"when": "editorHasSelection"
			},
			{
				"command": "lumi.focusChatInput",
				"key": "cmd+'",
				"mac": "cmd+'",
				"win": "ctrl+'",
				"linux": "ctrl+'",
				"when": "!editorHasSelection"
			}
		],
		"menus": {
			"editor/context": [
				{
					"command": "lumi.addToChat",
					"group": "navigation",
					"when": "editorHasSelection"
				}
			],
			"terminal/context": [
				{
					"command": "lumi.addTerminalOutputToChat",
					"group": "navigation"
				}
			],
			"scm/title": [
				{
					"command": "lumi.generateGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && !dietcode.isGeneratingCommit"
				},
				{
					"command": "lumi.abortGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && dietcode.isGeneratingCommit"
				}
			],
			"notebook/toolbar": [
				{
					"command": "lumi.jupyterGenerateCell",
					"group": "navigation/add@1",
					"when": "notebookType == 'jupyter-notebook'"
				}
			],
			"notebook/cell/title": [
				{
					"command": "lumi.jupyterExplainCell",
					"group": "inline@1",
					"when": "notebookType == 'jupyter-notebook'"
				},
				{
					"command": "lumi.jupyterImproveCell",
					"group": "inline@2",
					"when": "notebookType == 'jupyter-notebook'"
				}
			],
			"commandPalette": [
				{
					"command": "lumi.runHealthCheck",
					"title": "LUMI: Check Installation (Health Check)"
				},
				{
					"command": "lumi.generateGitCommitMessage",
					"when": "config.git.enabled && !dietcode.isGeneratingCommit"
				},
				{
					"command": "lumi.abortGitCommitMessage",
					"when": "config.git.enabled && dietcode.isGeneratingCommit"
				},
				{
					"command": "lumi.reviewComment.reply",
					"when": "false"
				}
			],
			"comments/commentThread/context": [
				{
					"command": "lumi.reviewComment.reply",
					"group": "inline",
					"when": "commentController == dietcode-review"
				}
			],
			"comments/commentThread/title": [
				{
					"command": "lumi.reviewComment.addToChat",
					"group": "inline",
					"when": "commentController == dietcode-review"
				}
			]
		},
		"configuration": {
			"title": "LUMI",
			"properties": {
				"lumi.roadmap.enabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable auto-rolling ROADMAP.md steering, gates, and checkpoint tools."
				},
				"lumi.roadmap.autoBootstrap": {
					"type": "boolean",
					"default": true,
					"description": "Auto-create ROADMAP.md from workspace evidence when missing."
				},
				"lumi.roadmap.autoBootstrapFill": {
					"type": "boolean",
					"default": true,
					"description": "Apply evidence autofill after bootstrap."
				},
				"lumi.roadmap.blockKanbanOnValidationPending": {
					"type": "boolean",
					"default": true,
					"description": "Block attempt_completion when ROADMAP.md changed since last validate."
				},
				"lumi.roadmap.failClosedCompletionGates": {
					"type": "boolean",
					"default": true,
					"description": "Block attempt_completion when roadmap gate evaluation fails."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run protos && cd webview-ui && npx vite build && cd .. && node esbuild.mjs --production",
		"compile": "npm run check-types && npm run lint && node esbuild.mjs",
		"dev": "npm run protos && npm run watch",
		"watch": "npx npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.mjs --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "npm run rebuild:electron:better-sqlite3 && npm run build:webview && npm run lint && node esbuild.mjs --production",
		"protos": "node scripts/build-proto.mjs",
		"protos-python": "node scripts/build-python-proto.mjs",
		"postprotos": "biome format src/shared/proto src/core/controller src/hosts/ webview-ui/src/services src/generated --write --no-errors-on-unmatched",
		"clean:build": "rimraf dist webview-ui/build src/generated out/",
		"clean:deps": "rimraf node_modules webview-ui/node_modules",
		"clean:all": "npm run clean:build && npm run clean:deps",
		"compile-tests": "node ./scripts/build-tests.js",
		"watch-tests": "tsc -p . -w --outDir out",
		"check-types": "npm run protos && npx tsc --noEmit && cd webview-ui && npx tsc --noEmit",
		"lint": "biome lint --no-errors-on-unmatched --files-ignore-unknown=true --diagnostic-level=error && npm run lint:proto && npm run check:handler-imports",
		"lint:proto": "bash ./scripts/proto-lint.sh",
		"format": "biome format --changed --no-errors-on-unmatched --files-ignore-unknown=true --diagnostic-level=error",
		"format:fix": "biome check --changed --no-errors-on-unmatched --files-ignore-unknown=true --write",
		"fix:all": "biome check --no-errors-on-unmatched --files-ignore-unknown=true --write --diagnostic-level=error --unsafe",
		"pin:actions": "node scripts/pin-github-actions.mjs",
		"ci:check-all": "npx npm-run-all -p check-types lint format roadmap:audit docs:check-agent-links docs:check-agent-branding docs:check-root-readme docs:check-root-readme-links docs:check-docs-readme docs:check-readme-metrics doctor:ci test:doctor",
		"ci:build": "npm run protos && npm run build:webview && node esbuild.mjs && npm run compile-tests",
		"pretest": "npm run compile && npm run compile-tests && npm run lint",
		"test": "npx npm-run-all test:unit test:integration",
		"test:integration": "vscode-test",
		"test:unit": "cross-env TS_NODE_PROJECT=./tsconfig.unit-test.json mocha",
		"test:unit:update-snapshots": "cross-env TS_NODE_PROJECT=./tsconfig.unit-test.json UPDATE_SNAPSHOTS=true mocha",
		"roadmap:audit": "npx ts-node -P tsconfig.unit-test.json -r tsconfig-paths/register scripts/roadmap_audit.ts",
		"test:coverage": "vscode-test --coverage",
		"e2e": "playwright test -c playwright.config.ts",
		"test:e2e:build": "npm run rebuild:electron:better-sqlite3 && vsce package --allow-package-secrets sendgrid --out dist/e2e.vsix",
		"test:e2e": "playwright install && npm run test:e2e:build && node src/test/e2e/utils/build.mjs && playwright test",
		"test:e2e:optimal": "npm run test:e2e:build && node src/test/e2e/utils/build.mjs && playwright test",
		"test:e2e:ui": "npx tsx scripts/interactive-playwright.ts",
		"install:all": "npm install && cd webview-ui && npm install",
		"dev:webview": "cd webview-ui && npm run dev",
		"build:webview": "cd webview-ui && npm run build",
		"test:webview": "cd webview-ui && npm run test",
		"package:vsix": "node scripts/package-vscode-vsix.mjs",
		"package:vsix:openvsx": "node scripts/package-openvsx-vsix.mjs",
		"package:vsix:all": "npm run package:vsix && npm run package:vsix:openvsx",
		"doctor": "node scripts/lumi-doctor.mjs",
		"doctor:fix": "node scripts/lumi-doctor.mjs --fix",
		"doctor:ci": "node scripts/lumi-doctor.mjs --ci",
		"doctor:install": "node scripts/lumi-doctor.mjs --install-only",
		"test:doctor": "node --test scripts/vsix-native-deps.test.mjs",
		"check:handler-imports": "node scripts/check-handler-imports.mjs",
		"audit:native-deps": "node scripts/lumi-doctor.mjs",
		"setup:openvsx": "node scripts/setup-openvsx-namespace.mjs",
		"publish:vscode": "node scripts/publish-vscode.mjs",
		"publish:vscode:prerelease": "node scripts/publish-vscode.mjs --pre-release",
		"publish:openvsx": "node scripts/publish-openvsx.mjs",
		"publish:openvsx:prerelease": "node scripts/publish-openvsx.mjs --pre-release",
		"publish:all": "npm run publish:vscode && npm run publish:openvsx",
		"publish:all:prerelease": "npm run publish:vscode:prerelease && npm run publish:openvsx:prerelease",
		"publish:marketplace": "npm run publish:all",
		"publish:marketplace:prerelease": "npm run publish:all:prerelease",
		"prepare": "npx husky",
		"docs": "cd docs && npm run dev",
		"docs:check-links": "cd docs && npm run check",
		"docs:check-agent-links": "node scripts/check-agent-docs-links.mjs",
		"docs:check-agent-branding": "node scripts/check-agent-docs-branding.mjs",
		"docs:check-root-readme": "node scripts/check-root-readme.mjs",
		"docs:check-docs-readme": "node scripts/check-docs-readme.mjs",
		"docs:check-all": "npx npm-run-all docs:check-agent-links docs:check-agent-branding docs:check-root-readme docs:check-root-readme-links docs:check-docs-readme docs:check-readme-metrics docs:check-links",
		"docs:check-readme-metrics": "node scripts/check-readme-metrics.mjs",
		"docs:check-root-readme-links": "node scripts/check-root-readme-links.mjs",
		"docs:tag-legacy-providers": "node scripts/tag-legacy-provider-docs.mjs",
		"docs:rename-file": "cd docs && npm run rename",
		"report-issue": "node scripts/report-issue.js",
		"storybook": "cd webview-ui && npm run storybook",
		"rebuild:electron": "electron-rebuild -v 39.2.3",
		"rebuild:electron:better-sqlite3": "node scripts/rebuild-electron-better-sqlite3.mjs"
	},
	"lint-staged": {
		"src/shared/storage/state-keys.ts": [
			"node scripts/generate-state-proto.mjs",
			"git add proto/dietcode/state.proto"
		],
		"*": [
			"biome check --write --staged --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.15",
		"@bufbuild/buf": "^1.54.0",
		"@electron/rebuild": "^4.0.6",
		"@types/adm-zip": "^0.5.8",
		"@types/better-sqlite3": "^7.6.13",
		"@types/chai": "^5.0.1",
		"@types/chokidar": "^1.7.5",
		"@types/clone-deep": "^4.0.4",
		"@types/diff": "^5.2.1",
		"@types/express": "^5.0.6",
		"@types/get-folder-size": "^3.0.4",
		"@types/js-yaml": "^4.0.9",
		"@types/minimatch": "^5.1.2",
		"@types/mocha": "^10.0.7",
		"@types/node": "^20.19.43",
		"@types/pdf-parse": "^1.1.4",
		"@types/picomatch": "^4.0.3",
		"@types/shell-quote": "^1.7.5",
		"@types/should": "^11.2.0",
		"@types/sinon": "^17.0.4",
		"@types/turndown": "^5.0.5",
		"@types/vscode": "1.84.2",
		"@types/ws": "^8.18.1",
		"@vscode/test-cli": "^0.0.15",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/vsce": "^3.6.0",
		"adm-zip": "^0.5.18",
		"c8": "^10.1.3",
		"chai": "^4.3.10",
		"chalk": "^5.6.2",
		"cross-env": "^10.1.0",
		"dotenv": "^17.2.4",
		"esbuild": "^0.28.1",
		"grpc-tools": "^1.13.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.0",
		"minimatch": "^3.0.3",
		"npm-run-all": "^4.1.5",
		"nyc": "^17.1.0",
		"prebuild-install": "^7.1.3",
		"protoc-gen-ts": "^0.8.7",
		"rimraf": "^6.1.3",
		"should": "^13.2.3",
		"sinon": "^19.0.2",
		"tree-kill": "^1.2.2",
		"ts-morph": "^27.0.2",
		"ts-node": "^10.9.2",
		"ts-proto": "^2.11.10",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.21.1",
		"typescript": "^5.4.5"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.37.0",
		"@anthropic-ai/vertex-sdk": "^0.6.4",
		"@aws-sdk/client-bedrock-runtime": "^3.922.0",
		"@aws-sdk/credential-providers": "^3.922.0",
		"@azure/identity": "^4.13.0",
		"@bufbuild/protobuf": "^2.2.5",
		"@cerebras/cerebras_cloud_sdk": "^1.35.0",
		"@google-cloud/vertexai": "^1.10.4",
		"@google/genai": "^1.45.0",
		"@grpc/grpc-js": "^1.9.15",
		"@grpc/reflection": "^1.0.4",
		"@mistralai/mistralai": "^1.14.1",
		"@modelcontextprotocol/sdk": "^1.25.1",
		"@noorm/broccolidb": "workspace:*",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/core": "^2.8.0",
		"@opentelemetry/exporter-logs-otlp-grpc": "^0.219.0",
		"@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
		"@opentelemetry/exporter-logs-otlp-proto": "^0.219.0",
		"@opentelemetry/exporter-metrics-otlp-grpc": "^0.219.0",
		"@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
		"@opentelemetry/exporter-metrics-otlp-proto": "^0.219.0",
		"@opentelemetry/exporter-prometheus": "^0.219.0",
