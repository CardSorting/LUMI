{
  "name": "@noorm/broccolidb",
  "version": "1.1.0",
  "description": "Stable operational substrate for agent-driven code work — capabilities, runtime, Spider, and durable snapshots.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "broccolidb": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist && find . -name '*.d.ts' -not -path './node_modules/*' -delete && find . -name '*.d.ts.map' -not -path './node_modules/*' -delete",
    "prepublishOnly": "npm run clean && npm run build",
    "format": "biome format --write .",
    "lint": "biome lint . && eslint .",
    "check": "biome check --write . && eslint .",
    "test": "node --import tsx/esm --test tests/*.test.ts 2>/dev/null || for f in tests/*.test.ts; do npx tsx \"$f\" || exit 1; done",
    "test:guardrails": "npx tsx tests/public-api-snapshot.test.ts && npx tsx tests/error-message.test.ts && npx tsx tests/no-experimental-public-names.test.ts && npx tsx tests/cli-smoke.test.ts && npx tsx tests/docs-link-check.test.ts",
    "test:examples": "npx tsx tests/examples-smoke.test.ts",
    "test:smoke": "npx tsx tests/runtime-recovery-smoke.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CardSorting/AIBroccoliDB.git"
  },
  "keywords": [
    "sqlite",
    "mcp",
    "database",
    "ai",
    "agent",
    "persistence",
    "async"
  ],
  "author": "DietCode",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/CardSorting/AIBroccoliDB/issues"
  },
  "homepage": "https://github.com/CardSorting/AIBroccoliDB#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "ignore": "^7.0.6",
    "kysely": "^0.28.14",
    "ora": "^9.3.0",
    "simple-git": "^3.33.0",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@eslint/js": "^9.39.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/eslint__js": "^9.14.0",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.5",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
